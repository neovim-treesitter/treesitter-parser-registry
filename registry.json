{
  "$schema": "https://raw.githubusercontent.com/neovim-treesitter/treesitter-parser-registry/main/schemas/schema.json",
  "ecma": {
    "source": {
      "type": "queries_only",
      "url": "https://github.com/neovim-treesitter/nvim-treesitter-queries-ecma",
      "semver": true
    }
  },
  "javascript": {
    "source": {
      "type": "external_queries",
      "parser_url": "https://github.com/tree-sitter/tree-sitter-javascript",
      "parser_semver": false,
      "queries_url": "https://github.com/neovim-treesitter/nvim-treesitter-queries-javascript",
      "queries_semver": true
    },
    "filetypes": ["javascript", "js"],
    "requires": ["ecma", "jsx"]
  },
  "python": {
    "source": {
      "type": "external_queries",
      "parser_url": "https://github.com/tree-sitter/tree-sitter-python",
      "parser_semver": true,
      "queries_url": "https://github.com/neovim-treesitter/nvim-treesitter-queries-python",
      "queries_semver": true
    },
    "filetypes": ["python", "py"]
  },
  "rust": {
    "source": {
      "type": "external_queries",
      "parser_url": "https://github.com/tree-sitter/tree-sitter-rust",
      "parser_semver": false,
      "queries_url": "https://github.com/neovim-treesitter/nvim-treesitter-queries-rust",
      "queries_semver": true
    },
    "filetypes": ["rust", "rs"]
  },
  "typescript": {
    "source": {
      "type": "external_queries",
      "parser_url": "https://github.com/tree-sitter/tree-sitter-typescript",
      "parser_semver": false,
      "parser_location": "typescript",
      "queries_url": "https://github.com/neovim-treesitter/nvim-treesitter-queries-typescript",
      "queries_semver": true
    },
    "filetypes": ["typescript", "ts"],
    "requires": ["ecma"]
  }
}
